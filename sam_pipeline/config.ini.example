[database]
server              = YOUR_SERVER
database            = Sam
username            = tom
password            = REPLACE_ME
driver              = ODBC Driver 18 for SQL Server
encrypt             = yes
trust_server_certificate = yes

[logging]
log_dir             = logs
max_bytes           = 10485760
backup_count        = 5

[pipeline]
batch_size          = 10000
template_table      = SAM_PUBLIC_MONTHLY_Empty

; SAM Pipeline configuration -- copy to config.ini and fill in credentials

[database]
server              = YOUR_SERVER
database            = Sam
username            = tom
password            = REPLACE_ME
driver              = ODBC Driver 18 for SQL Server
encrypt             = yes
trust_server_certificate = yes

[logging]
log_dir             = logs
max_bytes           = 10485760
backup_count        = 5

[pipeline]
batch_size          = 10000
template_table      = SAM_PUBLIC_MONTHLY_Empty

[portal]
url                 = https://api.sam.gov/data-services/v1/extracts
api_key             = REPLACE_ME
; download_url      = (optional) set a direct URL to skip the API call

[download]
temp_dir            = temp
connect_timeout     = 30
read_timeout        = 60
max_retries         = 3

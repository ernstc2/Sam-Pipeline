; SAM Pipeline configuration -- copy to config.ini and fill in credentials

[database]
server              = YOUR_SERVER
database            = Sam
username            = YOUR_USERNAME
password            = YOUR_PASSWORD
encrypt             = yes
trust_server_certificate = yes

[logging]
log_dir             = logs
max_bytes           = 10485760
backup_count        = 5

[pipeline]
batch_size          = 10000
input_dir           = input
temp_dir            = temp
; Optional: name of an existing view to repoint at each new monthly table
; after a successful load. Leave blank to disable. The view must already
; exist; its column list is preserved and only the source table is swapped.
current_view        = SAM_Current

[sam_api]
api_key             =

[cleanup]
; Optional: auto-delete old CSV exports that pile up from the monthly
; workflow. Leave csv_dir blank to disable. Only files in csv_dir matching
; csv_pattern AND older than retention_months are removed, and each deletion
; is logged. Keep csv_pattern narrow so nothing unrelated is ever touched.
csv_dir             =
csv_pattern         = *.csv
retention_months    = 3

; Used only by provision_contact_info.py (one-time). The source database that
; already has SAM_CONTACT_INFO; the script copies it into [database] above.
[contact_source]
server              = YOUR_SOURCE_SERVER
database            = Sam
username            = YOUR_USERNAME
password            = YOUR_PASSWORD
encrypt             = yes
trust_server_certificate = yes

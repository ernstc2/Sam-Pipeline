; SAM Pipeline configuration -- copy to config.ini and fill in credentials

[database]
server              = YOUR_SERVER
database            = Sam
username            = YOUR_USERNAME
password            = YOUR_PASSWORD
encrypt             = yes
trust_server_certificate = yes

[logging]
log_dir             = logs
max_bytes           = 10485760
backup_count        = 5

[pipeline]
batch_size          = 10000
input_dir           = input
temp_dir            = temp
; Optional: name of an existing view to repoint at each new monthly table
; after a successful load. Leave blank to disable. The view must already
; exist; its column list is preserved and only the source table is swapped.
current_view        = SAM_Current

[sam_api]
api_key             =

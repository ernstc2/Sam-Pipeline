; SAM Pipeline configuration -- copy to config.ini and fill in credentials

[database]
server              = YOUR_SERVER
database            = Sam
username            = tom
password            = REPLACE_ME
encrypt             = yes
trust_server_certificate = yes

[logging]
log_dir             = logs
max_bytes           = 10485760
backup_count        = 5

[pipeline]
batch_size          = 10000
template_table      = SAM_PUBLIC_MONTHLY_20250601
input_dir           = input
temp_dir            = temp

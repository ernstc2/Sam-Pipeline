; SAM Pipeline configuration -- copy to config.ini and fill in credentials

[database]
server              = YOUR_SERVER
database            = Sam
username            = YOUR_USERNAME
password            = YOUR_PASSWORD
encrypt             = yes
trust_server_certificate = yes

[logging]
log_dir             = logs
max_bytes           = 10485760
backup_count        = 5

[pipeline]
batch_size          = 10000
input_dir           = input
temp_dir            = temp

[sam_api]
api_key             = SAM-eb904e5d-6c69-4b57-90ce-5359b36ff370
